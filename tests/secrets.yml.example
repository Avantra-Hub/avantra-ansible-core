# Copy this file to secrets.yml and fill in the values.
# secrets.yml is gitignored and must never be committed.
#
# To encrypt with Ansible Vault:
#   ansible-vault encrypt tests/secrets.yml

# Avantra API credentials
avantra_api_user: "<your_avantra_user>"
avantra_api_password: "<your_avantra_password>"

# Test SAP system credentials
test_default_rfc_user: "<rfc_username>"
test_default_rfc_password: "<rfc_password>"

test_sap_control_user: "<sap_control_username>"
test_sap_control_password: "<sap_control_password>"

test_sap_user: "<sap_username>"
test_sap_password: "<sap_password>"

test_j2ee_user: "<j2ee_username>"
test_j2ee_password: "<j2ee_password>"

test_abap_db_user: "<abap_db_username>"
test_abap_db_password: "<abap_db_password>"

test_java_db_user: "<java_db_username>"
test_java_db_password: "<java_db_password>"
